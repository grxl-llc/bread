# Copy to .env and set for your environment.

# Where the frontend sends API requests.
#   • local dev:  http://localhost:8000  (or leave unset — this is the default)
#   • hosted/app: https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:8000

# Google Analytics 4 (optional — defaults to the live property in code)
# VITE_GA4_ID=G-XXXXXXXXXX
