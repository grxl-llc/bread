# ── Database ───────────────────────────────────────────────────────────────────
# SQLite for local dev:
DATABASE_URL=sqlite:///./bread.db
# PostgreSQL for production (RDS):
# DATABASE_URL=postgresql://user:password@your-rds-endpoint.us-east-1.rds.amazonaws.com:5432/bread

# ── JWT Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-long-random-string-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── AWS ────────────────────────────────────────────────────────────────────────
# On ECS/EC2 you can use IAM roles instead of keys — leave these blank then
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── S3 ─────────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=bread-app-media
# Set to your CloudFront domain once configured:
S3_PUBLIC_BASE_URL=

# ── Amazon IVS ─────────────────────────────────────────────────────────────────
IVS_REGION=us-east-1

# ── Kroger API ─────────────────────────────────────────────────────────────────
# Free developer credentials at: https://developer.kroger.com
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
